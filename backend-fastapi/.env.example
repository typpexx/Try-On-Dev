APP_NAME=Fashion Try-On API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/fashion_tryon
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8080,http://localhost:8081

# Auth (use a long random string in production)
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_EXPIRE_MINUTES=10080

# Google Sign-In: create OAuth 2.0 Client ID (Web) at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
