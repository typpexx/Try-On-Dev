APP_NAME=Fashion Try-On API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/fashion_tryon
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8080,http://localhost:8081

# Auth (use a long random string in production)
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_EXPIRE_MINUTES=10080

# Google Sign-In: create OAuth 2.0 Client ID (Web) at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
BACKEND_PUBLIC_URL=http://localhost:8000
EMAIL_VERIFICATION_EXPIRE_MINUTES=60

# SMTP (optional in development; if unset, verification link is printed in backend logs)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Stripe (dashboard: https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create a Product + Price (recurring) in Stripe, then paste the Price ID (e.g. price_xxx)
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_PRO_YEARLY=
